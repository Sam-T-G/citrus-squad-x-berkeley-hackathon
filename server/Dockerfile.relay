# Builds ONLY the belt relay (relay.py), the internet-fallback forwarder.
# The main belt server (app.py) is not hosted; it runs on the laptop next to the Arduino.
FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir "fastapi" "uvicorn[standard]" "websockets"
COPY relay.py .
ENV PORT=8090
EXPOSE 8090
CMD ["python", "relay.py"]
